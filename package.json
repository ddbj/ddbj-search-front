{
  "name": "ddbj-search-front",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "hook:check": "mise x -- hk check",
    "hook:fix": "mise x -- hk fix",
    "hook:install": "mise x -- hk install --mise",
    "dev": "vite",
    "dev:msw": "VITE_MSW=true vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "test": "vitest run --project=unit",
    "test:watch": "vitest --project=unit",
    "test:storybook": "vitest run --project=storybook",
    "test:storybook:watch": "vitest --project=storybook",
    "test:all": "vitest run",
    "test:all:watch": "vitest",
    "lint": "oxlint -c oxlint.config.ts . --quiet",
    "lint:debug": "oxlint -c oxlint.config.ts .",
    "lint:fix": "oxlint -c oxlint.config.ts . --fix --quiet",
    "format": "oxfmt -c oxfmt.config.ts .",
    "format:check": "oxfmt -c oxfmt.config.ts --check .",
    "type-check": "tsc -b --noEmit --pretty",
    "check-all": "pnpm run format && pnpm run lint && pnpm run type-check && pnpm run test",
    "fallow:dead": "fallow dead-code",
    "fallow:dupes": "fallow dupes",
    "fallow:health": "fallow health --score --file-scores"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@heroui/react": "^3.0.2",
    "@heroui/styles": "3.0.2",
    "@internationalized/date": "3.8.2",
    "@scalar/api-reference-react": "^0.9.32",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-query-devtools": "^5.96.2",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/zod-adapter": "^1.166.9",
    "@types/node": "^25.5.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@ver0/deep-equal": "^2.0.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "dompurify": "^3.3.3",
    "is-what": "^5.5.0",
    "jotai": "^2.19.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-syntax-highlighter": "^16.1.1",
    "serve": "^14.2.6",
    "tailwindcss": "^4.2.2",
    "usehooks-ts": "^3.1.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tanstack/eslint-plugin-router": "1.161.6",
    "@tanstack/router-plugin": "^1.167.12",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.3",
    "@vitest/browser-playwright": "^4.1.3",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^9.25.0",
    "eslint-plugin-storybook": "^10.3.5",
    "fallow": "^2.64.0",
    "msw": "^2.13.1",
    "msw-storybook-addon": "^2.0.6",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "pathe": "^2.0.3",
    "playwright": "^1.53.0",
    "storybook": "^10.3.5",
    "typescript": "~5.8.3",
    "vite": "^8.0.7",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.3"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
